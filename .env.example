APP_NAME=DavetKart
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=tr_TR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# SQLite works out of the box (database/database.sqlite).
DB_CONNECTION=sqlite
# For MySQL/PostgreSQL instead:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=davetkart
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Comma-separated SPA origins allowed by CORS (Vite dev server by default).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google GenAI proxy (POST /api/ai/generate). Leave empty to disable (501).
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.0-flash
